# DocMind — environment variables
# Copy this file to `.env` and fill in the values. Never commit `.env`.

# --- Supabase (Project Settings → API, and → API → JWT Settings) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- LLMs ---
GEMINI_API_KEY=          # https://aistudio.google.com
GROQ_API_KEY=            # https://console.groq.com

# --- Embeddings / rerank ---
COHERE_API_KEY=          # https://dashboard.cohere.com
